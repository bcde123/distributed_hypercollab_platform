# ─── HyperCollab — Environment Template ──────────────────────────────────────
# Copy this file to .env in the project root for docker-compose overrides,
# or use it as reference when deploying to a cloud provider.
# ──────────────────────────────────────────────────────────────────────────────

# ── Backend ───────────────────────────────────────────────────────────────────

# MongoDB — swap the Atlas URI in when deploying to the cloud
MONGO_URI=mongodb://mongo:27017/hypercollab

# JWT secrets — CHANGE THESE in production!
ACCESS_TOKEN_SECRET=change_me_in_production_access
REFRESH_TOKEN_SECRET=change_me_in_production_refresh

# CORS — comma-separated list of allowed origins (no trailing slash)
# Local dev:     http://localhost:5173
# Dockerised:    http://localhost
CORS_ORIGIN=http://localhost

# Redis — full URL takes precedence; fallback uses HOST+PORT
REDIS_URL=redis://redis:6379
# REDIS_HOST=redis
# REDIS_PORT=6379

# Kafka — internal broker address used by Node.js and C++ engine
KAFKA_BROKER=kafka:29092
KAFKAJS_NO_PARTITIONER_WARNING=1

# Email (for account notifications, optional)
# EMAIL_USER=your@email.com
# EMAIL_PASS=your_app_password
